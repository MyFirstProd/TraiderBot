APP_NAME=TraiderBot
APP_VERSION=0.1.0
APP_ENV=local
DEBUG=false
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
REQUESTS_PER_MINUTE=120

SECRET_KEY=change-me-to-32-plus-characters
ADMIN_API_KEY=change-me-to-32-plus-characters

DATABASE_URL=postgresql+asyncpg://traderbot:traderbot@postgres:5432/traderbot
REDIS_URL=redis://redis:6379/0

BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true
BYBIT_DEMO=false
BYBIT_CATEGORY=linear
BYBIT_TIMEOUT_SECONDS=10

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=[]
TELEGRAM_WEBHOOK_URL=
TELEGRAM_MINI_APP_URL=http://localhost:8000/api/v1/telegram/miniapp

LLM_ENABLED=false
LITELLM_API_BASE=http://litellm:4000
LITELLM_API_KEY=
LITELLM_MODEL=gpt-4o-mini
LITELLM_TIMEOUT_SECONDS=15

NEWS_ENABLED=true
NEWS_FEEDS=["https://www.coindesk.com/arc/outboundfeeds/rss/","https://forklog.com/feed/"]
WHALES_ENABLED=true
WHALE_ALERT_API_KEY=
TONAPI_KEY=

PAPER_TRADING=true
TRADING_ENABLED=false
STARTING_EQUITY=10000
TRADING_SYMBOLS=["BTCUSDT","ETHUSDT","TONUSDT"]
RISK_PER_TRADE_PCT=0.003
MAX_DAILY_LOSS_PCT=0.02
MAX_CONSECUTIVE_LOSSES=4
MAX_CONCURRENT_POSITIONS=3
MAX_TOTAL_EXPOSURE_PCT=0.35
CIRCUIT_BREAKER_ERRORS=5
MAX_SPREAD_BPS=8
EMERGENCY_SPREAD_BPS=18
MIN_VOLATILITY_BPS=10
MAX_VOLATILITY_BPS=180
RUNTIME_LOOP_SECONDS=10
